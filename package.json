{
  "name": "elysia-backend",
  "version": "1.0.0",
  "description": "ElysiaJS Backend API with PostgreSQL and Drizzle ORM",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/app/db/migrate.ts",
    "db:smart-migrate": "bun run src/app/db/syncMigrations.ts",
    "db:auto-migrate": "bun run db:generate && bun run db:smart-migrate",
    "db:update": "bun run db:generate && bun run db:migrate",
    "db:safe-update": "bun run db:backup && bun run db:generate && bun run db:migrate",
    "db:backup": "bun run src/app/db/dbBackupBun.ts",
    "db:restore": "bun run src/app/db/dbRestoreBun.ts",
    "db:backup-ts": "bun run src/app/db/dbBackup.ts",
    "db:restore-ts": "bun run src/app/db/dbRestore.ts",
    "db:reset": "bun run db:restore && bun run db:smart-migrate",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.3.3",
    "@elysiajs/jwt": "^1.3.3",
    "@elysiajs/swagger": "latest",
    "@types/node": "^24.3.1",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.5",
    "elysia": "^1.3.20",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3",
    "node-routeros": "^1.6.9",
    "otplib": "^12.0.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.2"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}