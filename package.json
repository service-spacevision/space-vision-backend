{
  "name": "elysia-backend",
  "version": "1.0.0",
  "description": "ElysiaJS Backend API with PostgreSQL and Drizzle ORM",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/app/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "elysia": "^1.3.20",
    "@elysiajs/swagger": "latest",
    "@elysiajs/jwt": "^1.3.3",
    "@elysiajs/cors": "^1.3.3",
    "drizzle-orm": "^0.44.5",
    "postgres": "^3.4.7",
    "bcryptjs": "^3.0.2",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.2"
  }
}